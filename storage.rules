rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos: profiles/{uid}/photos/{photoId}
    // - Authenticated users can read any profile photo (for viewing profiles)
    // - Only the profile owner can upload, update, or delete their own photos
    match /profiles/{userId}/photos/{photoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
