rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Dating profiles: one doc per user (profiles/{uid})
    // - Authenticated users can read any profile (for discovery/browsing)
    // - Only the owner can create, update, or delete their own profile
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Events: host-created docs with invite/check-in codes and mode controls.
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.hostId == request.auth.uid;
    }

    // Single active event membership per user (MVP).
    match /eventMemberships/{userId} {
      allow read, create, update, delete: if request.auth != null
        && request.auth.uid == userId;
    }
  }
}
