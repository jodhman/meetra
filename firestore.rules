rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Dating profiles: one doc per user (profiles/{uid})
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Events: host-created docs with invite/check-in codes and mode controls.
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.hostId == request.auth.uid;
    }

    // Roster + history: events/{eventId}/members/{memberUid}
    match /events/{eventId}/members/{memberUid} {
      allow read: if request.auth != null && (
        request.auth.uid == memberUid ||
        get(/databases/$(database)/documents/events/$(eventId)).data.hostId == request.auth.uid
      );
      allow create: if request.auth != null && request.auth.uid == memberUid
        && request.resource.data.role in ['host', 'participant']
        && request.resource.data.memberStatus in ['joined'];
      allow update: if request.auth != null && (
        request.auth.uid == memberUid ||
        get(/databases/$(database)/documents/events/$(eventId)).data.hostId == request.auth.uid
      );
      allow delete: if false;
    }

    // Single active event membership per user (MVP).
    match /eventMemberships/{userId} {
      allow read, create, update, delete: if request.auth != null
        && request.auth.uid == userId;
    }
  }
}
